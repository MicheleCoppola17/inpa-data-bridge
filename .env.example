APP_NAME=inpa-data-bridge
APP_ENV=dev
APP_VERSION=0.1.0
API_V1_PREFIX=/api/v1
LOG_LEVEL=INFO

DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/inpa

INPA_BASE_URL=https://portale.inpa.gov.it
INPA_SEARCH_PATH=/concorsi-smart/api/concorso-public-area/search-better
INPA_PAGE_SIZE=50
INPA_TIMEOUT_SECONDS=30
USER_AGENT=inpa-data-bridge/0.1.0

SYNC_ENABLED=true
SYNC_CRON=*/15 * * * *
SYNC_MAX_PAGES_PER_RUN=200
